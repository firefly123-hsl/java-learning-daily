<+>import characters.manager.Manager;\rimport characters.user.User;\rimport entity.hall.Hall;\rimport entity.movie.Movie;\rimport entity.order.Order;\rimport entity.order.OrderStatus;\rimport entity.seat.Seat;\rimport entity.session.Session;\rimport system.CinemaSystem;\r\rimport java.time.LocalDateTime;\rimport java.util.List;\rimport java.util.Scanner;\rimport java.util.regex.Pattern;\r\r/**\r * 影院购票系统 - 增强交互版\r * 核心：菜单式输入、全量输入校验、循环交互\r */\rpublic class CinemaInteractiveApplication {\r    // 全局系统单例\r    private static final CinemaSystem CINEMA_SYSTEM = CinemaSystem.getInstance();\r    // 控制台输入（全局复用）\r    private static final Scanner SCANNER = new Scanner(System.in);\r    // 正则表达式：校验11位手机号\r    private static final Pattern PHONE_PATTERN = Pattern.compile(\"^1[3-9]\\\\d{9}$\");\r    // 正则表达式：校验座位编码（如“1排2座”）\r    private static final Pattern SEAT_CODE_PATTERN = Pattern.compile(\"^\\\\d+排\\\\d+座$\");\r\r    // 当前登录的用户/管理员（全局共享）\r    private static User currentUser;\r    private static Manager currentManager;\r\r    public static void main(String[] args) {\r        System.out.println(\"===== 欢迎使用电影院购票系统 =====\");\r        // 初始化基础数据（仅启动时执行一次）\r        initSystemData();\r\r        // 主菜单循环（直到用户选择退出）\r        while (true) {\r            showMainMenu();\r            String mainChoice = SCANNER.nextLine().trim();\r            switch (mainChoice) {\r                case \"1\":\r                    // 管理员入口\r                    managerMenu();\r                    break;\r                case \"2\":\r                    // 用户入口\r                    userMenu();\r                    break;\r                case \"0\":\r                    // 退出系统\r                    System.out.println(\"感谢使用，系统已退出！\");\r                    SCANNER.close();\r                    return;\r                default:\r                    System.out.println(\"❌ 输入错误！请选择0-2之间的选项\");\r            }\r        }\r    }\r\r    /**\r     * 步骤1：初始化系统基础数据（仅启动时执行）\r     */\r    private static void initSystemData() {\r        System.out.println(\"\\n【系统初始化中...】\");\r        // 1. 创建电影\r        Movie movie1 = Movie.MovieFactory.createMovie(\"流浪地球3\", \"3D\");\r        Movie movie2 = Movie.MovieFactory.createMovie(\"满江红\", \"2D\");\r        CINEMA_SYSTEM.saveMovie(movie1);\r        CINEMA_SYSTEM.saveMovie(movie2);\r\r        // 2. 创建影厅并初始化座位\r        Hall hall1 = new Hall(\"HALL01\", \"1号普通厅\", \"普通\");\r        hall1.initSeats(5, 10, new int[]{1, 1}); // 1行是VIP座\r        CINEMA_SYSTEM.saveHall(hall1);\r\r        Hall hall2 = new Hall(\"HALL02\", \"2号VIP厅\", \"VIP\");\r        hall2.initSeats(3, 8, new int[]{1, 3}); // 1-3行都是VIP座\r        CINEMA_SYSTEM.saveHall(hall2);\r\r        // 3. 创建默认超级管理员（方便测试）\r        currentManager = new Manager(\"super_admin\", \"123456\", ManagerRole.SUPER_ADMIN, CINEMA_SYSTEM);\r        System.out.println(\"✅ 系统初始化完成！默认超级管理员：用户名super_admin，密码123456\");\r    }\r\r    /**\r     * 显示主菜单\r     */\r    private static void showMainMenu() {\r        System.out.println(\"\\n==================== 主菜单 ====================\");\r        System.out.println(\"1. 管理员入口\");\r        System.out.println(\"2. 普通用户入口\");\r        System.out.println(\"0. 退出系统\");\r        System.out.println(\"===============================================\");\r        System.out.print(\"请选择操作（输入数字）：\");\r    }\r\r    /**\r     * 管理员菜单（登录+子操作）\r     */\r    private static void managerMenu() {\r        // 1. 管理员登录\r        System.out.println(\"\\n==================== 管理员登录 ====================\");\r        System.out.print(\"请输入管理员用户名：\");\r        String adminName = SCANNER.nextLine();\r        System.out.print(\"请输入管理员密码：\");\r        String adminPwd = SCANNER.nextLine();\r\r\r        Manager manager = \"super_admin\".equals(adminName) ? currentManager : null;\r        if (manager == null) {\r            System.out.println(\"❌ 管理员不存在！\");\r            return;\r        }\r        boolean loginSuccess = manager.login(adminPwd, \"192.168.1.100\");\r        if (!loginSuccess) {\r            return;\r        }\r\r        // 2. 管理员子菜单循环\r        while (true) {\r            showManagerSubMenu();\r            String subChoice = SCANNER.nextLine().trim();\r            switch (subChoice) {\r                case \"1\":\r                    // 排片操作\r                    addSessionByManager(manager);\r                    break;\r                case \"2\":\r                    // 修改影厅状态\r                    changeHallStatusByManager(manager);\r                    break;\r                case \"3\":\r                    // 统计票房\r                    statBoxOfficeByManager(manager);\r                    break;\r                case \"0\":\r                    // 返回主菜单\r                    System.out.println(\"\uD83D\uDD19 回到主菜单\");\r                    return;\r                default:\r                    System.out.println(\"❌ 输入错误！请选择0-3之间的选项\");\r            }\r        }\r    }\r\r    /**\r     * 显示管理员子菜单\r     */\r    private static void showManagerSubMenu() {\r        System.out.println(\"\\n==================== 管理员操作 ====================\");\r        System.out.println(\"1. 新增电影场次\");\r        System.out.println(\"2. 修改影厅状态\");\r        System.out.println(\"3. 统计电影票房\");\r        System.out.println(\"0. 返回主菜单\");\r        System.out.println(\"===============================================\");\r        System.out.print(\"请选择操作（输入数字）：\");\r    }\r\r    /**\r     * 普通用户菜单（注册/登录+子操作）\r     */\r    private static void userMenu() {\r        while (true) {\r            showUserLoginMenu();\r            String loginChoice = SCANNER.nextLine().trim();\r            switch (loginChoice) {\r                case \"1\":\r                    // 用户注册\r                    registerUser();\r                    break;\r                case \"2\":\r                    // 用户登录\r                    if (loginUser()) {\r                        // 登录成功，进入用户子菜单\r                        userSubMenu();\r                    }\r                    break;\r                case \"0\":\r                    // 返回主菜单\r                    System.out.println(\"\uD83D\uDD19 回到主菜单\");\r                    return;\r                default:\r                    System.out.println(\"❌ 输入错误！请选择0-2之间的选项\");\r            }\r        }\r    }\r\r    /**\r     * 显示用户登录/注册菜单\r     */\r    private static void showUserLoginMenu() {\r        System.out.println(\"\\n==================== 用户入口 ====================\");\r        System.out.println(\"1. 新用户注册\");\r        System.out.println(\"2. 老用户登录\");\r        System.out.println(\"0. 返回主菜单\");\r        System.out.println(\"===============================================\");\r        System.out.print(\"请选择操作（输入数字）：\");\r    }\r\r    /**\r     * 显示用户子菜单（登录后）\r     */\r    private static void showUserSubMenu() {\r        System.out.println(\"\\n==================== 用户操作 ====================\");\r        System.out.println(\"1. 购票选座\");\r        System.out.println(\"2. 查看我的订单\");\r        System.out.println(\"3. 申请订单退款\");\r        System.out.println(\"0. 返回上一级\");\r        System.out.println(\"===============================================\");\r        System.out.print(\"请选择操作（输入数字）：\");\r    }\r\r    // ------------------- 管理员核心操作（带输入交互） -------------------\r    /**\r     * 管理员新增场次（带输入交互+校验）\r     */\r    private static void addSessionByManager(Manager manager) {\r        System.out.println(\"\\n==================== 新增场次 ====================\");\r        // 1. 显示可选电影\r        List<Movie> movies = CINEMA_SYSTEM.getAllMovies();\r        System.out.println(\"可选电影列表：\");\r        for (int i = 0; i < movies.size(); i++) {\r            System.out.printf(\"%d. %s（%s，时长%d分钟）%n\", i + 1, movies.get(i).getName(), movies.get(i).getType(), movies.get(i).getDuration());\r        }\r        System.out.print(\"请选择电影（输入数字）：\");\r        String movieChoice = SCANNER.nextLine().trim();\r        int movieIndex;\r        try {\r            movieIndex = Integer.parseInt(movieChoice) - 1;\r            if (movieIndex < 0 || movieIndex >= movies.size()) {\r                System.out.println(\"❌ 电影选择错误！\");\r                return;\r            }\r        } catch (NumberFormatException e) {\r            System.out.println(\"❌ 输入不是数字！\");\r            return;\r        }\r        Movie selectedMovie = movies.get(movieIndex);\r\r        // 2. 显示可选影厅\r        List<Hall> halls = CINEMA_SYSTEM.getAllHalls();\r        System.out.println(\"\\n可选影厅列表：\");\r        for (int i = 0; i < halls.size(); i++) {\r            System.out.printf(\"%d. %s（%s，状态：%s）%n\", i + 1, halls.get(i).getHallName(), halls.get(i).getHallType(), halls.get(i).getHallStatus());\r        }\r        System.out.print(\"请选择影厅（输入数字）：\");\r        String hallChoice = SCANNER.nextLine().trim();\r        int hallIndex;\r        try {\r            hallIndex = Integer.parseInt(hallChoice) - 1;\r            if (hallIndex < 0 || hallIndex >= halls.size()) {\r                System.out.println(\"❌ 影厅选择错误！\");\r                return;\r            }\r        } catch (NumberFormatException e) {\r            System.out.println(\"❌ 输入不是数字！\");\r            return;\r        }\r        Hall selectedHall = halls.get(hallIndex);\r\r        // 3. 输入场次时间\r        System.out.print(\"\\n请输入场次开始时间（格式：yyyy-MM-dd HH:mm，如2025-12-04 19:00）：\");\r        String timeStr = SCANNER.nextLine().trim();\r        LocalDateTime startTime;\r        try {\r            // 简化时间解析（实际可使用DateTimeFormatter）\r            String[] timeParts = timeStr.split(\" \");\r            String[] dateParts = timeParts[0].split(\"-\");\r            String[] hourParts = timeParts[1].split(\":\");\r            startTime = LocalDateTime.of(\r                    Integer.parseInt(dateParts[0]),\r                    Integer.parseInt(dateParts[1]),\r                    Integer.parseInt(dateParts[2]),\r                    Integer.parseInt(hourParts[0]),\r                    Integer.parseInt(hourParts[1])\r            );\r        } catch (Exception e) {\r            System.out.println(\"❌ 时间格式错误！\");\r            return;\r        }\r\r        // 4. 新增场次\r        boolean success = manager.addSession(selectedMovie, selectedHall.getHallId(), startTime, \"192.168.1.100\");\r        if (success) {\r            System.out.println(\"✅ 场次新增成功！\");\r        } else {\r            System.out.println(\"❌ 场次新增失败！\");\r        }\r    }\r\r    /**\r     * 管理员修改影厅状态（带输入交互）\r     */\r    private static void changeHallStatusByManager(Manager manager) {\r        System.out.println(\"\\n==================== 修改影厅状态 ====================\");\r        // 1. 显示影厅列表\r        List<Hall> halls = CINEMA_SYSTEM.getAllHalls();\r        System.out.println(\"影厅列表：\");\r        for (int i = 0; i < halls.size(); i++) {\r            System.out.printf(\"%d. %s（ID：%s，当前状态：%s）%n\", i + 1, halls.get(i).getHallName(), halls.get(i).getHallId(), halls.get(i).getHallStatus());\r        }\r        System.out.print(\"请选择影厅（输入数字）：\");\r        String hallChoice = SCANNER.nextLine().trim();\r        int hallIndex;\r        try {\r            hallIndex = Integer.parseInt(hallChoice) - 1;\r            if (hallIndex < 0 || hallIndex >= halls.size()) {\r                System.out.println(\"❌ 影厅选择错误！\");\r                return;\r            }\r        } catch (NumberFormatException e) {\r            System.out.println(\"❌ 输入不是数字！\");\r            return;\r        }\r        Hall selectedHall = halls.get(hallIndex);\r\r        // 2. 选择新状态\r        System.out.println(\"\\n可选状态：\");\r        System.out.println(\"1. 正常\");\r        System.out.println(\"2. 维护中\");\r        System.out.println(\"3. 已停用\");\r        System.out.print(\"请选择新状态（输入数字）：\");\r        String statusChoice = SCANNER.nextLine().trim();\r        HallStatus newStatus;\r        switch (statusChoice) {\r            case \"1\":\r                newStatus = HallStatus.NORMAL;\r                break;\r            case \"2\":\r                newStatus = HallStatus.MAINTENANCE;\r                break;\r            case \"3\":\r                newStatus = HallStatus.DISABLED;\r                break;\r            default:\r                System.out.println(\"❌ 状态选择错误！\");\r                return;\r        }\r\r        // 3. 输入备注\r        System.out.print(\"请输入状态修改备注：\");\r        String remark = SCANNER.nextLine().trim();\r\r        // 4. 修改状态\r        boolean success = manager.changeHallStatus(selectedHall.getHallId(), newStatus, remark, \"192.168.1.100\");\r        if (success) {\r            System.out.println(\"✅ 影厅状态修改成功！\");\r        } else {\r            System.out.println(\"❌ 影厅状态修改失败！\");\r        }\r    }\r\r    /**\r     * 管理员统计票房（带输入交互）\r     */\r    private static void statBoxOfficeByManager(Manager manager) {\r        System.out.println(\"\\n==================== 票房统计 ====================\");\r        // 1. 显示电影列表\r        List<Movie> movies = CINEMA_SYSTEM.getAllMovies();\r        System.out.println(\"可选电影列表：\");\r        for (int i = 0; i < movies.size(); i++) {\r            System.out.printf(\"%d. %s%n\", i + 1, movies.get(i).getName());\r        }\r        System.out.print(\"请选择要统计的电影（输入数字）：\");\r        String movieChoice = SCANNER.nextLine().trim();\r        int movieIndex;\r        try {\r            movieIndex = Integer.parseInt(movieChoice) - 1;\r            if (movieIndex < 0 || movieIndex >= movies.size()) {\r                System.out.println(\"❌ 电影选择错误！\");\r                return;\r            }\r        } catch (NumberFormatException e) {\r            System.out.println(\"❌ 输入不是数字！\");\r            return;\r        }\r        Movie selectedMovie = movies.get(movieIndex);\r\r        // 2. 统计并显示票房\r        double boxOffice = manager.getBoxOfficeByMovie(selectedMovie, \"192.168.1.100\");\r        System.out.printf(\"✅ 电影【%s】总票房：%.2f 元%n\", selectedMovie.getName(), boxOffice);\r    }\r\r    // ------------------- 普通用户核心操作（带输入交互） -------------------\r    /**\r     * 用户注册（带输入校验）\r     */\r    private static void registerUser() {\r        System.out.println(\"\\n==================== 新用户注册 ====================\");\r        // 1. 输入用户名（非空+唯一）\r        String username;\r        while (true) {\r            System.out.print(\"请输入用户名：\");\r            username = SCANNER.nextLine().trim();\r            if (username.isEmpty()) {\r                System.out.println(\"❌ 用户名不能为空！\");\r                continue;\r            }\r            if (CINEMA_SYSTEM.checkUserExist(username)) {\r                System.out.println(\"❌ 用户名已存在！\");\r                continue;\r            }\r            break;\r        }\r\r        // 2. 输入密码（长度≥6）\r        String password;\r        while (true) {\r            System.out.print(\"请输入密码（长度≥6）：\");\r            password = SCANNER.nextLine().trim();\r            if (password.length() < 6) {\r                System.out.println(\"❌ 密码长度不足6位！\");\r                continue;\r            }\r            break;\r        }\r\r        // 3. 输入手机号（11位数字）\r        String phone;\r        while (true) {\r            System.out.print(\"请输入手机号（11位数字）：\");\r            phone = SCANNER.nextLine().trim();\r            if (!PHONE_PATTERN.matcher(phone).matches()) {\r                System.out.println(\"❌ 手机号格式错误！\");\r                continue;\r            }\r            if (CINEMA_SYSTEM.checkPhoneExist(phone)) {\r                System.out.println(\"❌ 手机号已注册！\");\r                continue;\r            }\r            break;\r        }\r\r        // 4. 完成注册\r        User user = new User(username, password, phone);\r        boolean success = user.register();\r        if (success) {\r            System.out.println(\"✅ 注册成功！请登录\");\r        } else {\r            System.out.println(\"❌ 注册失败！\");\r        }\r    }\r\r    /**\r     * 用户登录（带输入校验）\r     * @return 登录是否成功\r     */\r    private static boolean loginUser() {\r        System.out.println(\"\\n==================== 老用户登录 ====================\");\r        System.out.print(\"请输入用户名：\");\r        String username = SCANNER.nextLine().trim();\r        System.out.print(\"请输入密码：\");\r        String password = SCANNER.nextLine().trim();\r\r        // 1. 校验用户是否存在\r        User user = CINEMA_SYSTEM.getUserByUsername(username);\r        if (user == null) {\r            System.out.println(\"❌ 用户名不存在！\");\r            return false;\r        }\r\r        // 2. 校验密码\r        boolean success = user.login(username,password);\r        if (success) {\r            currentUser = user;\r            System.out.println(\"✅ 登录成功！\");\r            return true;\r        } else {\r            System.out.println(\"❌ 密码错误！\");\r            return false;\r        }\r    }\r\r    /**\r     * 用户子菜单（登录后操作）\r     */\r    private static void userSubMenu() {\r        while (true) {\r            showUserSubMenu();\r            String subChoice = SCANNER.nextLine().trim();\r            switch (subChoice) {\r                case \"1\":\r                    // 购票选座\r                    buyTicketByUser();\r                    break;\r                case \"2\":\r                    // 查看我的订单\r                    viewUserOrders();\r                    break;\r                case \"3\":\r                    // 申请退款\r                    applyRefundByUser();\r                    break;\r                case \"0\":\r                    // 返回上一级\r                    System.out.println(\"\uD83D\uDD19 回到用户登录菜单\");\r                    currentUser = null;\r                    return;\r                default:\r                    System.out.println(\"❌ 输入错误！请选择0-3之间的选项\");\r            }\r        }\r    }\r\r    /**\r     * 用户购票选座（带输入交互+校验）\r     */\r    private static void buyTicketByUser() {\r        System.out.println(\"\\n==================== 购票选座 ====================\");\r        // 1. 选择电影\r        List<Movie> movies = CINEMA_SYSTEM.getAllMovies();\r        System.out.println(\"可选电影列表：\");\r        for (int i = 0; i < movies.size(); i++) {\r            System.out.printf(\"%d. %s（%s）%n\", i + 1, movies.get(i).getName(), movies.get(i).getType());\r        }\r        System.out.print(\"请选择电影（输入数字）：\");\r        String movieChoice = SCANNER.nextLine().trim();\r        int movieIndex;\r        try {\r            movieIndex = Integer.parseInt(movieChoice) - 1;\r            if (movieIndex < 0 || movieIndex >= movies.size()) {\r                System.out.println(\"❌ 电影选择错误！\");\r                return;\r            }\r        } catch (NumberFormatException e) {\r            System.out.println(\"❌ 输入不是数字！\");\r            return;\r        }\r        Movie selectedMovie = movies.get(movieIndex);\r\r        // 2. 选择场次\r        List<Session> sessions = CINEMA_SYSTEM.getSessionsByMovie(selectedMovie);\r        if (sessions.isEmpty()) {\r            System.out.println(\"❌ 该电影暂无可购票场次！\");\r            return;\r        }\r        System.out.println(\"\\n可选场次列表：\");\r        for (int i = 0; i < sessions.size(); i++) {\r            Hall hall = CINEMA_SYSTEM.getHallById(sessions.get(i).getHallId());\r            System.out.printf(\"%d. %s - %s（%s）%n\", i + 1, sessions.get(i).getStartTime(), hall.getHallName(), sessions.get(i).getSessionId());\r        }\r        System.out.print(\"请选择场次（输入数字）：\");\r        String sessionChoice = SCANNER.nextLine().trim();\r        int sessionIndex;\r        try {\r            sessionIndex = Integer.parseInt(sessionChoice) - 1;\r            if (sessionIndex < 0 || sessionIndex >= sessions.size()) {\r                System.out.println(\"❌ 场次选择错误！\");\r                return;\r            }\r        } catch (NumberFormatException e) {\r            System.out.println(\"❌ 输入不是数字！\");\r            return;\r        }\r        Session selectedSession = sessions.get(sessionIndex);\r\r        // 3. 选择座位\r        Hall hall = CINEMA_SYSTEM.getHallById(selectedSession.getHallId());\r        System.out.printf(\"\\n%s 座位布局：%d行×%d列（1排为VIP座）%n\", hall.getHallName(), hall.getTotalRows(), hall.getTotalCols());\r        System.out.print(\"请输入要选择的座位（多个座位用逗号分隔，如1排2座,1排3座）：\");\r        String seatInput = SCANNER.nextLine().trim();\r        String[] seatCodeArray = seatInput.split(\",\");\r        List<String> seatCodes = List.of(seatCodeArray);\r\r        // 校验座位编码格式\r        for (String seatCode : seatCodes) {\r            if (!SEAT_CODE_PATTERN.matcher(seatCode.trim()).matches()) {\r                System.out.println(\"❌ 座位编码格式错误：\" + seatCode + \"（正确格式：X排Y座）\");\r                return;\r            }\r        }\r\r        // 4. 锁定座位\r        List<Seat> lockedSeats = CINEMA_SYSTEM.lockSeats(selectedSession, seatCodes);\r        if (lockedSeats.isEmpty()) {\r            System.out.println(\"❌ 座位锁定失败（已被占用/不存在）\");\r            return;\r        }\r        System.out.printf(\"✅ 成功锁定座位：%s%n\", lockedSeats.stream().map(Seat::getSeatCode).reduce((a, b) -> a + \",\" + b).orElse(\"\"));\r\r        // 5. 创建订单\r        Order order = new Order(currentUser, selectedSession, lockedSeats);\r        // 可选：应用优惠\r        System.out.print(\"是否使用优惠（Y/N）：\");\r        String discountChoice = SCANNER.nextLine().trim();\r        if (\"Y\".equalsIgnoreCase(discountChoice)) {\r            System.out.print(\"请输入优惠金额：\");\r            String discountStr = SCANNER.nextLine().trim();\r            try {\r                double discount = Double.parseDouble(discountStr);\r                order.applyDiscount(discount);\r            } catch (NumberFormatException e) {\r                System.out.println(\"❌ 优惠金额格式错误！跳过优惠\");\r            }\r        }\r        CINEMA_SYSTEM.saveOrder(order);\r        System.out.println(\"\\n\uD83D\uDCDD 订单信息：\");\r        System.out.println(order.getOrderDetail());\r\r        // 6. 支付订单\r        System.out.print(\"是否立即支付（Y/N）：\");\r        String payChoice = SCANNER.nextLine().trim();\r        if (\"Y\".equalsIgnoreCase(payChoice)) {\r            System.out.println(\"\\n可选支付方式：\");\r            System.out.println(\"1. 支付宝\");\r            System.out.println(\"2. 微信支付\");\r            System.out.println(\"3. 银行卡支付\");\r            System.out.print(\"请选择支付方式（输入数字）：\");\r            String payTypeChoice = SCANNER.nextLine().trim();\r            PayType payType;\r            switch (payTypeChoice) {\r                case \"1\":\r                    payType = PayType.ALIPAY;\r                    break;\r                case \"2\":\r                    payType = PayType.WECHAT;\r                    break;\r                case \"3\":\r                    payType = PayType.BANK_CARD;\r                    break;\r                default:\r                    System.out.println(\"❌ 支付方式选择错误！默认使用微信支付\");\r                    payType = PayType.WECHAT;\r            }\r            boolean paySuccess = order.payOrder(payType, order.getActualAmount());\r            if (paySuccess) {\r                System.out.println(\"✅ 支付成功！购票完成，祝您观影愉快～\");\r            } else {\r                System.out.println(\"❌ 支付失败！订单已取消，座位已解锁\");\r                order.cancelOrder();\r            }\r        } else {\r            System.out.println(\"\uD83D\uDD14 您已放弃支付，订单将在15分钟后超时取消\");\r        }\r    }\r\r    /**\r     * 用户查看我的订单\r     */\r    private static void viewUserOrders() {\r        System.out.println(\"\\n==================== 我的订单 ====================\");\r        List<Order> userOrders = CINEMA_SYSTEM.getOrdersByUser(currentUser);\r        if (userOrders.isEmpty()) {\r            System.out.println(\"\uD83D\uDCED 您暂无订单\");\r            return;\r        }\r        for (int i = 0; i < userOrders.size(); i++) {\r            Order order = userOrders.get(i);\r            System.out.printf(\"--- 订单%d ---%n\", i + 1);\r            System.out.println(order.getOrderDetail());\r        }\r    }\r\r    /**\r     * 用户申请退款\r     */\r    private static void applyRefundByUser() {\r        System.out.println(\"\\n==================== 申请退款 ====================\");\r        List<Order> userOrders = CINEMA_SYSTEM.getOrdersByUser(currentUser);\r        if (userOrders.isEmpty()) {\r            System.out.println(\"\uD83D\uDCED 您暂无订单可退款\");\r            return;\r        }\r\r        // 显示可退款订单（已支付且未开场）\r        List<Order> refundableOrders = userOrders.stream()\r                .filter(order -> order.getOrderStatus() == OrderStatus.PAID)\r                .filter(order -> {\r                    Session session = CINEMA_SYSTEM.getSessionById(order.getSessionId());\r                    return session != null && LocalDateTime.now().isBefore(session.getStartTime());\r                })\r                .collect(java.util.stream.Collectors.toList());\r\r        if (refundableOrders.isEmpty()) {\r            System.out.println(\"\uD83D\uDCED 您暂无可退款的订单（仅已支付且未开场的订单可退款）\");\r            return;\r        }\r\r        // 选择要退款的订单\r        System.out.println(\"可退款订单列表：\");\r        for (int i = 0; i < refundableOrders.size(); i++) {\r            Order order = refundableOrders.get(i);\r            System.out.printf(\"%d. 订单ID：%s，金额：%.2f元，场次：%s%n\",\r                    i + 1, order.getOrderId(), order.getActualAmount(), order.getSessionId());\r        }\r        System.out.print(\"请选择要退款的订单（输入数字）：\");\r        String orderChoice = SCANNER.nextLine().trim();\r        int orderIndex;\r        try {\r            orderIndex = Integer.parseInt(orderChoice) - 1;\r            if (orderIndex < 0 || orderIndex >= refundableOrders.size()) {\r                System.out.println(\"❌ 订单选择错误！\");\r                return;\r            }\r        } catch (NumberFormatException e) {\r            System.out.println(\"❌ 输入不是数字！\");\r            return;\r        }\r        Order selectedOrder = refundableOrders.get(orderIndex);\r\r        // 输入退款原因\r        System.out.print(\"请输入退款原因：\");\r        String refundReason = SCANNER.nextLine().trim();\r\r        // 模拟管理员审批退款（实际项目中需管理员审核，此处简化为直接退款）\r        Manager financeAdmin = new Manager(\"finance_admin\", \"123456\", ManagerRole.FINANCE_ADMIN, CINEMA_SYSTEM);\r        boolean refundSuccess = financeAdmin.approveRefund(selectedOrder.getOrderId(), refundReason, \"192.168.1.101\");\r        if (refundSuccess) {\r            System.out.println(\"✅ 退款申请已通过！金额将原路返回\");\r        } else {\r            System.out.println(\"❌ 退款申请失败！\");\r        }\r    }\r}
