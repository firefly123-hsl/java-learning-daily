<+>package system;\r\rimport characters.user.User;\rimport entity.hall.Hall;\rimport entity.movie.Movie;\rimport entity.order.Order;\rimport entity.seat.Seat;\rimport entity.session.Session;\r\rimport java.time.LocalDateTime;\rimport java.util.ArrayList;\rimport java.util.List;\rimport java.util.Map;\rimport java.util.concurrent.ConcurrentHashMap;\r\rpublic class CinemaSystem {\r    private static volatile CinemaSystem instance;\r    private final Map<String, User> userMap = new ConcurrentHashMap<>();\r    private final Map<String, Movie> movieMap = new ConcurrentHashMap<>();\r    private final Map<String, Hall> hallMap = new ConcurrentHashMap<>();\r    private final Map<String, Session> sessionMap = new ConcurrentHashMap<>();\r    private final Map<String, Order> orderMap = new ConcurrentHashMap<>();\r    private final int orderTimeoutMinutes = 15; // 订单超时未支付时间（15分钟）\r    private final int seatLockTimeoutMinutes = 15; // 座位锁定超时时间\r    private CinemaSystem(){\r    }\r    public static CinemaSystem getInstance(){\r        if(instance == null){\r            synchronized (CinemaSystem.class){\r                if(instance == null){\r                    instance = new CinemaSystem();\r                }\r            }\r        }\r        return instance;\r    }\r\r    // ------------------- 用户管理模块 -------------------\r\r    //保存用户\r    public boolean saveUser(User user){\r        if(!checkUserExist(user.getUsername())){\r            userMap.put(user.getUsername(), user);\r            return true;\r        }\r        return false;\r    }\r\r    //由用户Id获取用户类\r    public User getUserByUsername(String username){\r        return userMap.get(username);\r    }\r\r    //判断是否存在该用户名\r    public boolean checkUserExist(String username) {\r        return userMap.containsKey(username);\r    }\r\r    //校验登录密码是否正确\r    public boolean verifyUserPassword(String username, String inputPassword){\r        String  rightPassword=userMap.get(username).getPassword();\r        return   rightPassword.equals(inputPassword);\r    }\r\r    //获取所有用户\r    public List<User> getUserList(){\r        return new ArrayList<>(userMap.values());\r    }\r\r    // ------------------- 电影管理模块 -------------------\r\r    //保存电影\r    public boolean saveMovie(Movie movie){\r        if(!checkMovieExist(movie.getMovieName())){\r            movieMap.put(movie.getMovieName(), movie);\r            return true;\r        }\r        return false;\r    }\r\r    //下架电影\r    public boolean deleteMovie(String  movieName){\r        Movie movie=movieMap.get(movieName);\r        if(movie==null){\r            System.out.println(\"删除失败：电影不存在\");\r            return false;\r        }\r        //检验关联场次是否结束\r        List<Session> sessions=getSessionsByMovie();\r        boolean hasActiveSession=sessions.stream()\r                .anyMatch(session->session.getEndTime().isAfter(LocalDateTime.now()));\r        if(hasActiveSession){\r            System.out.println(\"删除失败：电影仍有关联的未结束场次\");\r            return false;\r        }\r        //检验电影映期是否结束\r        if(movie.getReleaseDate().plusDays(movie.getDuration()).isAfter(LocalDateTime.now())){\r            System.out.println(\"删除失败：电影映期尚未结束\");\r            return false;\r        }\r        movieMap.remove(movieName);\r        System.out.println(\"电影【\\\" + movie.getName() + \\\"】删除成功\");\r        return true;\r    }\r\r    //由电影名获取电影(精确查找）\r    public Movie getMovieByName(String movieName){\r        return movieMap.get(movieName);\r    }\r\r    //由电影名获取电影（模糊查找）\r    public List<Movie> searchMovieByKeyword(String keyword){\r        List<Movie> result=new ArrayList<>();\r        for(Movie movie:movieMap.values()){\r            if(movie.getMovieName().contains(keyword)){\r                result.add(movie);\r            }\r        }\r        return result;\r    }\r\r    //判断是否存在该电影名\r    public boolean checkMovieExist(String movieName) {\r        return movieMap.containsKey(movieName);\r    }\r\r    //获取所有电影\r    public List<Movie> getMovies(){\r        List<Movie> movies=new ArrayList<>(movieMap.values());\r        //降序（新上映的在前）\r        movies.sort((m1,m2)-> m2.getReleaseDate().compareTo(m1.getReleaseDate()));\r        return movies;\r    }\r\r    //获取电影的所有场次\r    public List<Session> getSessionsByMovie(String movieName){\r        Movie movie=movieMap.get(movieName);\r        List<Session> sessions=new ArrayList<>();\r        for(Session session:sessionMap.values()){\r            if(session.getMovie().equals(movieName)){\r                sessions.add(session);\r            }\r        }\r        //早的在前面\r        sessions.sort((s1,s2)->s1.getEndTime().compareTo(s2.getEndTime()));\r        return sessions;\r    }\r\r    // ------------------- 影厅管理模块 -------------------\r\r    public boolean saveHall(Hall hall){\r\r    }\r    public Hall getHallByName(String hallName){\r\r    }\r    public List<Hall> getHalls(){\r        return new ArrayList<>(hallMap.values());\r    }\r    public List<Hall> getFreeHalls(){\r\r    }\r\r    // ------------------- 场次管理模块 -------------------\r\r    public boolean saveSession(Session session){\r\r    }\r    public Session getSessionByName(String sessionName){\r\r    }\r    public List<Session> getSessionsByMovie(){\r\r    }\r    public List<Session> getSessionsByHall(){\r\r    }\r    /**\r     * 清理所有影厅的过期锁定座位（定时任务调用）\r     */\r    public void cleanAllExpiredLockedSeats() {\r\r    }\r\r    // ------------------- 订单管理模块 -------------------\r\r    public boolean saveOrder(Order order){\r\r    }\r    public Order getOrderByName(String orderName){\r\r    }\r    public List<Order> getOrdersByUser(){\r\r    }\r    /**\r     * 清理超时未支付订单（定时任务调用）\r     */\r    public void cleanExpiredOrders() {\r\r    }\r\r    // ------------------- 座位管控模块（全局核心） -------------------\r\r    public List<Seat> lockSeats(Session session, List<String> seatCodes){\r\r    }\r    public void unlockSeats(List<Seat> seats){\r\r    }\r\r}\r
